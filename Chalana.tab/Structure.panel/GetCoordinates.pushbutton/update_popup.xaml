<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Update Available" Height="220" Width="400" WindowStartupLocation="CenterScreen"
        Background="Black" WindowStyle="None" AllowsTransparency="False">
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/> <!-- Title Bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
            <RowDefinition Height="Auto"/> <!-- Buttons -->
        </Grid.RowDefinitions>

        <!-- TITLE BAR -->
        <Grid Grid.Row="0" Background="#1A1A1A" Height="30" MouseLeftButtonDown="TitleBar_MouseDown">
            <TextBlock Text="Get Coordinates - Update System" Foreground="#888888" FontSize="11" VerticalAlignment="Center" Margin="15,0,0,0"/>
            <Button x:Name="CloseBtn" Content="✕" Width="40" HorizontalAlignment="Right" Background="Transparent" Foreground="#666666" BorderThickness="0" Click="CancelButton_Click"/>
        </Grid>

        <!-- CONTENT -->
        <StackPanel Grid.Row="1" Margin="25,20,25,0">
            <TextBlock Text="Update Available" Foreground="#802F2D" FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
            <TextBlock x:Name="UpdateMessage" Text="A new version of the Get Coordinates tool is available on GitHub." Foreground="#BBBBBB" FontSize="12" TextWrapping="Wrap"/>
        </StackPanel>

        <!-- BUTTONS -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,0,20,20">
            <Button x:Name="LaterBtn" Content="Later" Width="80" Height="32" Background="#2A2A2A" Foreground="#AAAAAA" BorderThickness="0" Margin="0,0,10,0" Cursor="Hand" Click="CancelButton_Click"/>
            <Button x:Name="UpdateBtn" Content="Update Now" Width="120" Height="32" Background="#802F2D" Foreground="White" BorderThickness="0" FontWeight="Bold" Cursor="Hand" Click="UpdateNow_Click">
                <Button.Style>
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#A03B38"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Button.Style>
            </Button>
        </StackPanel>
    </Grid>
</Window>
